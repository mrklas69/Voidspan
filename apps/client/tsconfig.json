{
  "compilerOptions": {
    // Cílový JS výstup + lib: moderní browser prostředí
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    // Strict mode — povinné pro FVP (dle dohody S8)
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    // Bundler-friendly: Vite si obsluhuje emit sám
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,

    // Vite client types — `import.meta.env.DEV` apod.
    "types": ["vite/client"]
  },
  "include": ["src"]
}
